{
  "CORSRules": [
    {
      "AllowedOrigins": [
        "https://nz-temple-vercel-static.vercel.app",
        "https://*.vercel.app",
        "http://localhost:5001",
        "http://127.0.0.1:5001"
      ],
      "AllowedMethods": [
        "GET",
        "HEAD"
      ],
      "AllowedHeaders": [
        "*"
      ],
      "ExposeHeaders": [
        "Content-Length",
        "Content-Type",
        "Content-Range",
        "Accept-Ranges"
      ],
      "MaxAgeSeconds": 3600
    }
  ]
}
